  "pins": [
    {
      "pin_number": "1",
      "pin_name": "RT",
      "pin_type": "A",
      "description": "Frequency programming input. Float for 500kHz, tie to GND for 1.2MHz, or connect to an RT timing resistor for 200kHz–2.2MHz range. Frequency is latched at first enable."
    },
    {
      "pin_number": "2",
      "pin_name": "EN",
      "pin_type": "A",
      "description": "Enable input. Driving high or leaving floating enables the converter. An external resistor divider can implement adjustable VIN UVLO. Has internal pullup current of 0.7µA."
    },
    {
      "pin_number": "3",
      "pin_name": "VIN",
      "pin_type": "P",
      "description": "Supply input pin to internal LDO and high-side FET. Input bypass capacitors must be connected directly to this pin and GND."
    },
    {
      "pin_number": "4",
      "pin_name": "GND",
      "pin_type": "G",
      "description": "Ground pin. Connected to source of low-side FET and controller ground. Connect to system ground and ground side of CIN and COUT. Path to CIN must be as short as possible."
    },
    {
      "pin_number": "5",
      "pin_name": "SW",
      "pin_type": "P",
      "description": "Switching output of the converter. Internally connected to source of high-side FET and drain of low-side FET. Connect to the power inductor."
    },
    {
      "pin_number": "6",
      "pin_name": "BST",
      "pin_type": "P",
      "description": "Bootstrap capacitor connection for high-side FET driver. Connect a high-quality 100nF ceramic capacitor from this pin to the SW pin."
    },
    {
      "pin_number": "7",
      "pin_name": "SS/PG",
      "pin_type": "A",
      "description": "Dual-function pin. On TPS62932/TPS62933/TPS62933F: soft-start control, external capacitor sets reference voltage rise time, minimum 6.8nF required, do not float. On TPS62933P/TPS62933O: open-drain power-good indicator, pulled low when output is out of regulation, in OVP, thermal shutdown, EN shutdown, or during soft-start."
    },
    {
      "pin_number": "8",
      "pin_name": "FB",
      "pin_type": "A",
      "description": "Output feedback input. Connect to tap of external resistor divider from output to GND to set output voltage. Internal reference is 0.8V."
    }
  ],
